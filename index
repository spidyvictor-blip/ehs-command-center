  "Safety":    "#E65100","Security":"#3730A3","EHS":"#065F46","Ergo":"#5B21B6",
  "Env":"#164E63","Energy":"#92400E","Leadership":"#1E40AF"
};
function renderSchedule(){
  document.getElementById('schedule-body').innerHTML = SCHEDULE.map((s,i)=>{
    const fs = FREQ_STYLE[s.freq]||{bg:"#33415544",text:"#94A3B8"};
    const catClr = CAT_STYLE[s.cat]||"#64748B";
    const isTeam = s.task.includes('⭐');
    return `<tr style="${isTeam?'background:#FCE7F311;':''}">
      <td style="font-family:'JetBrains Mono',monospace;font-size:11px;color:#7EB8F7;white-space:nowrap">${s.day}</td>
      <td style="font-weight:${isTeam?700:400};color:${isTeam?'#F8FAFC':'var(--text)'}">${s.task}</td>
      <td style="color:var(--mid);white-space:nowrap;font-size:11px">${s.who}</td>
      <td><span style="background:${fs.bg};color:${fs.text};border-radius:20px;padding:2px 8px;font-size:10px;font-weight:700">${s.freq}</span></td>
      <td><span style="color:${catClr};font-size:10px;font-weight:700">${s.cat}</span></td>
    </tr>`;
  }).join('');
}

// ── TAB SWITCHING ─────────────────────────────────────────────────────────────
const TABS = ['overview','actions','vpp','team','schedule'];
function switchTab(id){
  TABS.forEach(t=>{
    document.getElementById(`section-${t}`).classList.toggle('section-hidden', t!==id);
    document.getElementById(`section-${t}`).classList.toggle('fade-in', t===id);
    document.getElementById(`tab-${t}`).classList.toggle('active', t===id);
  });
  window.scrollTo({top:0,behavior:'smooth'});
}

// ── INIT ──────────────────────────────────────────────────────────────────────
renderKPI();
renderScorecard();
renderStatusTiles();
renderVPPMini();
renderVPPFull();
renderActionsTable();
renderTeam();
renderSchedule();
</script>
