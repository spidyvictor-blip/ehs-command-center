// ── HELPERS ──────────────────────────────────────────────────────────────────
const byStatus = s => ACTIONS.filter(a => a.status === s).length;
const total = ACTIONS.length;
const pctDone = Math.round(byStatus("Complete") / total * 100);

function badgeClass(status){
  return 'badge badge-' + status.replace(/\s+/g,'-').replace('-','');
}

function progColor(pct){
  return pct >= 75 ? '#10B981' : pct >= 40 ? '#F59E0B' : '#EF4444';
}

function progBar(pct,color){
  return `<div class="prog-track"><div class="prog-fill" style="width:${Math.min(pct,100)}%;background:${color||progColor(pct)}"></div></div>`;
}

