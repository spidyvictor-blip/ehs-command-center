// ── RENDER ACTIONS TABLE ──────────────────────────────────────────────────────
let filteredActions = [...ACTIONS];
function applyFilters(){
  const person  = document.getElementById('f-person').value;
  const status  = document.getElementById('f-status').value;
  const program = document.getElementById('f-program').value;
  const pri     = document.getElementById('f-pri').value;
  const search  = document.getElementById('f-search').value.toLowerCase();
  filteredActions = ACTIONS.filter(a=>{
    if(person!=='All' && a.person!==person) return false;
    if(status!=='All' && a.status!==status) return false;
    if(program!=='All' && a.program!==program) return false;
    if(pri!=='All' && a.pri!==pri) return false;
    if(search && !a.task.toLowerCase().includes(search) && !a.owner.toLowerCase().includes(search)) return false;
    return true;
  });
  renderActionsTable();
}
function clearFilters(){
  ['f-person','f-status','f-program','f-pri'].forEach(id=>document.getElementById(id).value='All');
  document.getElementById('f-search').value='';
  applyFilters();
}
function renderActionsTable(){
  const count = document.getElementById('filter-count');
  count.innerHTML = `Showing <strong>${filteredActions.length}</strong> of ${ACTIONS.length} actions`;
  const tbody = document.getElementById('actions-body');
  if(!filteredActions.length){
    tbody.innerHTML = `<tr><td colspan="7" style="padding:32px;text-align:center;color:var(--dim)">No actions match your filters.</td></tr>`;
    return;
  }
  const clr = TEAM_COLORS;
  tbody.innerHTML = filteredActions.map(a=>`
    <tr>
      <td style="max-width:320px;${a.status==='Complete'?'text-decoration:line-through;color:var(--dim)':''}">${a.task}</td>
      <td style="color:var(--mid);white-space:nowrap">${a.owner}</td>
      <td><span class="${badgeClass(a.status)}">${a.status}</span></td>
      <td><span class="pri-${a.pri}">${a.pri}</span></td>
      <td style="color:#7EB8F7;white-space:nowrap;font-size:11px;font-family:'JetBrains Mono',monospace">${a.target}</td>
      <td style="white-space:nowrap;font-weight:600;color:${clr[a.person]||'var(--mid)'};font-size:11px">${a.person.split(' ')[0]}</td>
      <td style="color:var(--dim);font-size:11px">${a.program}</td>
    </tr>`).join('');
}

