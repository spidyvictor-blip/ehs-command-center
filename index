<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>EHS Command Center · GE Aerospace Muskegon</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet"/>
<style>
/* ── RESET & BASE ─────────────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#060E1C;
  --deep:#0A1628;
  --panel:#0D1F3C;
  --border:#1A3054;
  --accent:#0EA5E9;
  --green:#10B981;
  --green-lt:#D1FAE5;
  --amber:#F59E0B;
  --amber-lt:#FEF3C7;
  --red:#EF4444;
  --red-lt:#FEE2E2;
  --purple:#8B5CF6;
  --teal:#0DB9A0;
  --gold:#D97706;
  --slate:#334155;
  --mid:#94A3B8;
  --dim:#475569;
  --text:#E2E8F0;
  --heading:#F8FAFC;
  --stripe:#0B1A30;
  --input-bg:#0F2340;
  --radius:10px;
  --shadow:0 4px 24px rgba(0,0,0,.4);
}
html{scroll-behavior:smooth}
body{font-family:'Inter',system-ui,sans-serif;background:var(--navy);color:var(--text);min-height:100vh;overflow-x:hidden}

/* ── SCROLLBAR ────────────────────────────────────────────────────────── */
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:var(--deep)}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px}

/* ── TOPBAR ──────────────────────────────────────────────────────────── */
#topbar{
  position:sticky;top:0;z-index:100;
  background:rgba(6,14,28,.95);
  backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
}
.topbar-inner{
  max-width:1400px;margin:0 auto;
  padding:0 24px;
  display:flex;align-items:stretch;justify-content:space-between;gap:16px;
  flex-wrap:wrap;
}
.brand{padding:14px 0 10px;display:flex;flex-direction:column;gap:3px}
.brand-title{font-size:15px;font-weight:900;letter-spacing:-.3px;color:var(--heading);display:flex;align-items:center;gap:8px}
.brand-title .dot{width:8px;height:8px;border-radius:50%;background:var(--accent);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.8)}}
.brand-sub{font-size:11px;color:var(--mid);font-family:'JetBrains Mono',monospace}
.vpp-badge{
  display:inline-flex;align-items:center;gap:5px;
  background:linear-gradient(135deg,#78350F44,#D9770622);
  border:1px solid #D9770644;
  border-radius:20px;padding:2px 10px;
  font-size:10px;font-weight:700;color:var(--gold);
  margin-left:8px;
}

/* NAV TABS */
.nav-tabs{display:flex;align-items:flex-end;gap:2px;padding-bottom:0}
.nav-tab{
  display:flex;align-items:center;gap:6px;
  padding:12px 16px;
  background:transparent;border:none;
  color:var(--dim);font-size:12px;font-weight:600;
  cursor:pointer;border-bottom:3px solid transparent;
  transition:all .15s;white-space:nowrap;
  font-family:'Inter',sans-serif;
}
.nav-tab:hover{color:var(--text)}
.nav-tab.active{color:var(--heading);border-bottom-color:var(--accent)}

/* ── MAIN ────────────────────────────────────────────────────────────── */
main{max-width:1400px;margin:0 auto;padding:24px 24px 48px}

/* ── PANEL CARD ───────────────────────────────────────────────────────── */
.card{
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:var(--radius);
  overflow:hidden;
}
.card-header{
  padding:12px 18px;
  background:rgba(13,43,85,.8);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;gap:12px;
  flex-wrap:wrap;
}
.card-title{font-size:11px;font-weight:700;color:var(--mid);letter-spacing:1px;text-transform:uppercase}
.card-title span{color:var(--accent);margin-right:6px}

/* ── KPI GRID ────────────────────────────────────────────────────────── */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:10px;margin-bottom:16px}
.kpi-card{
  background:var(--panel);border:1px solid var(--border);
  border-radius:var(--radius);overflow:hidden;
  transition:transform .15s,box-shadow .15s;cursor:default;
}
.kpi-card:hover{transform:translateY(-2px);box-shadow:var(--shadow)}
.kpi-accent{height:3px}
.kpi-body{padding:14px 16px 12px}
.kpi-val{font-size:28px;font-weight:900;line-height:1;letter-spacing:-1px}
.kpi-label{font-size:10px;font-weight:700;color:var(--mid);margin-top:6px;text-transform:uppercase;letter-spacing:.5px}
.kpi-sub{font-size:10px;color:var(--dim);margin-top:2px}

/* ── STATUS BADGE ─────────────────────────────────────────────────────── */
.badge{
  display:inline-flex;align-items:center;gap:4px;
  border-radius:20px;padding:2px 9px;
  font-size:10px;font-weight:700;white-space:nowrap;
}
.badge::before{content:'';width:5px;height:5px;border-radius:50%;flex-shrink:0}
.badge-Complete{background:#D1FAE533;color:#34D399}.badge-Complete::before{background:#10B981}
.badge-OnSchedule,.badge-on-schedule{background:#CFFAFE33;color:#22D3EE}.badge-OnSchedule::before,.badge-on-schedule::before{background:#0DB9A0}
.badge-Behind{background:#FEE2E233;color:#F87171}.badge-Behind::before{background:#EF4444}
.badge-AtRisk,.badge-at-risk{background:#FEF3C733;color:#FCD34D}.badge-AtRisk::before,.badge-at-risk::before{background:#F59E0B}
.badge-NotStarted,.badge-not-started{background:#EEF2FF33;color:#A5B4FC}.badge-NotStarted::before,.badge-not-started::before{background:#8B5CF6}
.badge-Open{background:#33415533;color:#94A3B8}.badge-Open::before{background:#64748B}
.badge-Ongoing{background:#CFFAFE22;color:#67E8F9}.badge-Ongoing::before{background:#0DB9A0}
.badge-OnHold,.badge-on-hold{background:#FEF3C722;color:#FCD34D}.badge-OnHold::before,.badge-on-hold::before{background:#F59E0B}

/* PRI */
.pri-High{background:#FEE2E233;color:#F87171;border-radius:8px;padding:1px 7px;font-size:10px;font-weight:700}
.pri-Medium{background:#FEF3C733;color:#FCD34D;border-radius:8px;padding:1px 7px;font-size:10px;font-weight:700}
.pri-Low{background:#D1FAE533;color:#34D399;border-radius:8px;padding:1px 7px;font-size:10px;font-weight:700}

/* ── PROGRESS BAR ─────────────────────────────────────────────────────── */
.prog-track{background:#1A3054;border-radius:6px;height:7px;overflow:hidden;width:100%}
.prog-fill{height:100%;border-radius:6px;transition:width .5s cubic-bezier(.4,0,.2,1)}

/* ── GRID LAYOUTS ─────────────────────────────────────────────────────── */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.three-col{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
@media(max-width:900px){.two-col,.three-col{grid-template-columns:1fr}}

/* ── TABLE ────────────────────────────────────────────────────────────── */
.tbl-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:12px}
thead tr{background:#0B1825}
th{padding:9px 14px;color:var(--dim);font-size:10px;font-weight:700;text-align:left;
   border-bottom:1px solid var(--border);letter-spacing:.5px;text-transform:uppercase;white-space:nowrap}
td{padding:9px 14px;border-bottom:1px solid var(--border);vertical-align:middle}
tbody tr{transition:background .1s}
tbody tr:nth-child(even){background:var(--stripe)}
tbody tr:hover{background:#0D2448}

/* ── FILTER BAR ──────────────────────────────────────────────────────── */
.filter-bar{display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;padding:14px 18px}
.filter-group{display:flex;flex-direction:column;gap:4px}
.filter-label{font-size:10px;font-weight:700;color:var(--dim);text-transform:uppercase;letter-spacing:.8px}
select,input[type=text]{
  background:var(--input-bg);color:var(--text);
  border:1px solid var(--border);border-radius:6px;
  padding:6px 10px;font-size:12px;font-family:'Inter',sans-serif;
  outline:none;cursor:pointer;min-width:130px;
}
select:focus,input:focus{border-color:var(--accent)}
input[type=text]{min-width:200px}
.filter-count{font-size:11px;color:var(--dim);align-self:flex-end;padding-bottom:6px}
.filter-count strong{color:var(--accent)}
.btn-clear{
  background:#1A3054;color:var(--mid);border:1px solid var(--border);
  border-radius:6px;padding:6px 14px;font-size:11px;font-weight:600;
  cursor:pointer;font-family:'Inter',sans-serif;transition:all .15s;
  align-self:flex-end;
}
.btn-clear:hover{background:var(--border);color:var(--text)}

/* ── TEAM CARDS ──────────────────────────────────────────────────────── */
.team-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px}
.team-card{background:var(--panel);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
.team-card-header{padding:12px 16px;border-bottom:1px solid var(--border)}
.team-name{font-size:14px;font-weight:800}
.team-role{font-size:10px;color:var(--mid);margin-top:2px}
.team-body{padding:14px 16px;display:flex;flex-direction:column;gap:10px}
.team-stat-row{display:flex;justify-content:space-between;gap:8px}
.team-stat{text-align:center;flex:1}
.team-stat-val{font-size:18px;font-weight:800;line-height:1}
.team-stat-lbl{font-size:9px;color:var(--dim);margin-top:2px}
.behind-list{display:flex;flex-direction:column;gap:4px;margin-top:4px}
.behind-item{font-size:10px;color:#FCA5A5;background:#EF444411;border:1px solid #EF444422;border-radius:5px;padding:4px 8px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* ── VPP MILESTONE ────────────────────────────────────────────────────── */
.milestone-row{
  display:flex;align-items:center;gap:16px;
  padding:12px 18px;border-bottom:1px solid var(--border);
  transition:background .1s;flex-wrap:wrap;
}
.milestone-row:hover{background:#0D2448}
.milestone-row:last-child{border-bottom:none}
.milestone-num{
  width:30px;height:30px;border-radius:50%;
  background:var(--panel);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:800;color:var(--accent);
  flex-shrink:0;font-family:'JetBrains Mono',monospace;
}
.milestone-goal .milestone-num{border-color:var(--gold);color:var(--gold)}
.milestone-text{flex:1;min-width:180px}
.milestone-ms{font-size:13px;font-weight:500;color:var(--text)}
.milestone-goal .milestone-ms{font-weight:800;color:var(--gold)}
.milestone-meta{font-size:10px;color:var(--dim);margin-top:2px}
.milestone-prog{min-width:160px;display:flex;flex-direction:column;gap:4px}
.milestone-pct-row{display:flex;justify-content:space-between;font-size:10px;color:var(--dim)}
.milestone-pct-val{font-weight:800}

/* ── STATUS BREAKDOWN TILES ───────────────────────────────────────────── */
.status-tiles{display:grid;grid-template-columns:repeat(auto-fit,minmax(100px,1fr));gap:8px;padding:14px 18px}
.status-tile{
  background:var(--stripe);border:1px solid var(--border);
  border-radius:8px;padding:12px 14px;text-align:center;
  cursor:pointer;transition:transform .15s,box-shadow .15s;
}
.status-tile:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.3)}
.status-tile-val{font-size:24px;font-weight:900;line-height:1}
.status-tile-lbl{font-size:9px;font-weight:700;margin-top:4px;text-transform:uppercase;letter-spacing:.5px}
.status-tile-pct{font-size:9px;color:var(--dim);margin-top:2px}

/* ── SECTION SPACING ─────────────────────────────────────────────────── */
.section{display:flex;flex-direction:column;gap:14px}
.section-hidden{display:none}

/* ── FOOTER ──────────────────────────────────────────────────────────── */
footer{
  border-top:1px solid var(--border);
  padding:16px 24px;text-align:center;
  font-size:10px;color:var(--dim);
  font-family:'JetBrains Mono',monospace;
  letter-spacing:.3px;
}

/* ── ANIMATE IN ───────────────────────────────────────────────────────── */
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.fade-in{animation:fadeUp .3s ease both}

/* ── RESPONSIVE ──────────────────────────────────────────────────────── */
@media(max-width:640px){
  .kpi-grid{grid-template-columns:repeat(2,1fr)}
  .topbar-inner{flex-direction:column;gap:0}
  .nav-tabs{overflow-x:auto;width:100%}
  main{padding:14px 14px 40px}
}
</style>
</head>
<body>

<!-- ══ TOPBAR ══════════════════════════════════════════════════════════════ -->
<div id="topbar">
  <div class="topbar-inner">
    <div class="brand">
      <div class="brand-title">
        <span class="dot"></span>
        EHS COMMAND CENTER
        <span class="vpp-badge">⭐ VPP Star · Oct 2026</span>
      </div>
      <div class="brand-sub">GE Aerospace Muskegon · 2026 Strategic Action Plan</div>
    </div>
    <nav class="nav-tabs" role="tablist">
      <button class="nav-tab active" onclick="switchTab('overview')" id="tab-overview">📊 Overview</button>
      <button class="nav-tab" onclick="switchTab('actions')"  id="tab-actions">✅ Actions</button>
      <button class="nav-tab" onclick="switchTab('vpp')"      id="tab-vpp">⭐ VPP Path</button>
      <button class="nav-tab" onclick="switchTab('team')"     id="tab-team">👥 Team</button>
      <button class="nav-tab" onclick="switchTab('schedule')" id="tab-schedule">📅 Schedule</button>
    </nav>
  </div>
</div>

<!-- ══ MAIN ════════════════════════════════════════════════════════════════ -->
<main>

<!-- ████ OVERVIEW ████ -->
<div id="section-overview" class="section fade-in">

