      </div>
      <div class="status-tiles" id="status-tiles"></div>
    </div>

  </div>

  <!-- VPP progress summary -->
  <div class="card">
    <div class="card-header">
      <span class="card-title"><span>⭐</span>VPP Star Path — October 2026</span>
      <span id="vpp-avg-badge" style="font-size:11px;font-weight:700;color:var(--gold)"></span>
    </div>
    <div id="vpp-mini"></div>
  </div>

</div>

<!-- ████ ACTIONS ████ -->
<div id="section-actions" class="section section-hidden fade-in">
  <div class="card">
    <div class="card-header">
      <span class="card-title"><span>🔍</span>Filter Actions</span>
    </div>
    <div class="filter-bar">
      <div class="filter-group">
        <label class="filter-label">Person</label>
        <select id="f-person" onchange="applyFilters()">
          <option>All</option>
          <option>Victor Pizarro</option><option>Steve Wolbrink</option>
          <option>Mike Shuster</option><option>Rich DeLeau</option><option>Zach Tindall</option>
        </select>
      </div>
      <div class="filter-group">
        <label class="filter-label">Status</label>
        <select id="f-status" onchange="applyFilters()">
          <option>All</option>
          <option>Complete</option><option>On Schedule</option><option>Behind</option>
          <option>At-Risk</option><option>Not Started</option><option>Open</option>
          <option>Ongoing</option><option>On Hold</option>
        </select>
      </div>
      <div class="filter-group">
        <label class="filter-label">Program</label>
        <select id="f-program" onchange="applyFilters()">
          <option>All</option><option>Core EHS</option><option>Ergo</option>
          <option>VPP</option><option>Security</option>
        </select>
      </div>
      <div class="filter-group">
        <label class="filter-label">Priority</label>
        <select id="f-pri" onchange="applyFilters()">
          <option>All</option><option>High</option><option>Medium</option><option>Low</option>
        </select>
      </div>
      <div class="filter-group">
        <label class="filter-label">Search</label>
        <input type="text" id="f-search" placeholder="Task or owner…" oninput="applyFilters()"/>
      </div>
      <span class="filter-count" id="filter-count"></span>
      <button class="btn-clear" onclick="clearFilters()">Clear All</button>
    </div>
  </div>

  <div class="card">
    <div class="tbl-wrap">
      <table>
        <thead><tr>
          <th>Action Item</th><th>Owner</th><th>Status</th>
          <th>Priority</th><th>Target</th><th>Person</th><th>Program</th>
        </tr></thead>
        <tbody id="actions-body"></tbody>
      </table>
    </div>
  </div>
</div>

<!-- ████ VPP ████ -->
<div id="section-vpp" class="section section-hidden fade-in">
  <div class="card">
    <div class="card-header" style="background:linear-gradient(135deg,#78350F22,#D9770611)">
      <div>
        <div class="card-title" style="color:var(--gold);font-size:12px">⭐ VPP Star Milestone Tracker</div>
        <div style="font-size:11px;color:var(--mid);margin-top:2px">Update percentage complete as milestones progress · Target: October 2026</div>
      </div>
      <div style="text-align:right">
        <div id="vpp-avg-large" style="font-size:28px;font-weight:900;color:var(--gold)"></div>
        <div style="font-size:10px;color:var(--dim)">Avg Progress</div>
      </div>
    </div>
    <div id="vpp-full"></div>
  </div>
</div>

<!-- ████ TEAM ████ -->
<div id="section-team" class="section section-hidden fade-in">
  <div class="team-grid" id="team-grid"></div>
</div>

<!-- ████ SCHEDULE ████ -->
<div id="section-schedule" class="section section-hidden fade-in">
  <div class="card">
    <div class="card-header">
      <span class="card-title"><span>📅</span>Team Weekly Schedule Snapshot</span>
      <span style="font-size:10px;color:var(--dim)">Standing meetings & hard commitments</span>
    </div>
    <div class="tbl-wrap">
      <table id="schedule-table">
        <thead><tr><th>Day / Time</th><th>Meeting / Task</th><th>Who</th><th>Frequency</th><th>Category</th></tr></thead>
        <tbody id="schedule-body"></tbody>
      </table>
    </div>
  </div>
</div>

</main>

